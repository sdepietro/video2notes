# Copiá este archivo a .env y completá tu key:  cp .env.example .env
# El archivo .env NO se sube a git (está en .gitignore).
OPENAI_API_KEY=sk-...

# --- Opcionales (tienen valores por defecto) ---

# Modelo de transcripción.
#   whisper-1          -> recomendado, sin límite de duración (solo 25 MB de archivo)
#   gpt-4o-transcribe  -> mejor calidad PERO corta en ~23 min de audio
STT_MODEL=whisper-1

# Modelo para generar la minuta.
LLM_MODEL=gpt-4o

# Idioma del audio (ISO-639-1). Forzarlo evita que la IA detecte mal el idioma.
# Ej: es (español), en (inglés), pt (portugués). Vacío = detección automática.
LANGUAGE=es
